# Super Admin Killer environment variables
# Copy this file to:
#   scripts/env/superkiller.env
# Then use:
#   source scripts/import-env.sh
# or:
#   scripts/import-env.sh -- mvn -pl sak-service spring-boot:run

# Backend
SERVER_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=123456

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=replace-with-your-own-jwt-secret
JWT_AT_EXPIRE=10m
JWT_RT_EXPIRE=7d

# Mail
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# WxPusher
WXPUSHER_ENABLED=false
WXPUSHER_APP_TOKEN=
WXPUSHER_BASE_URL=https://wxpusher.zjiecode.com
WXPUSHER_CONTENT_TYPE=1

# ip2region
IP2REGION_ENABLED=true
IP2REGION_IPV4_DB=./ip2region/ip2region_v4.xdb
IP2REGION_IPV6_DB=
IP2REGION_IPV4_CLASSPATH=
IP2REGION_IPV6_CLASSPATH=

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_TITLE=SuperKiller Admin

# Runtime / startup
SPRING_PROFILES_ACTIVE=local
JAVA_HOME=
JAVA_OPTS=
SPRING_OPTS=
